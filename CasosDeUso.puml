@startuml
left to right direction
skinparam monochrome true
skinparam shadowing false
skinparam packageStyle rectangle

actor Usuario as U
actor Amigo as A
actor "Serviço de IA" as IA
actor "Base de Alimentos" as BA

rectangle Luma {
  usecase "Definir metas" as UC1
  usecase "Registrar refeição" as UC2
  usecase "Registrar por foto" as UC2a
  usecase "Registrar por código de barras" as UC2b
  usecase "Registrar por busca" as UC2c
  usecase "Acompanhar progresso" as UC3
  usecase "Gerenciar amizades" as UC4
  usecase "Participar de grupo de streak" as UC5
  usecase "Publicar no feed" as UC6
  usecase "Reagir e comentar publicações" as UC7
  usecase "Enviar mensagem" as UC8
  usecase "Compartilhar/criar receita" as UC9
  usecase "Receber notificações" as UC10
}

U -- UC1
U -- UC2
U -- UC3
U -- UC4
U -- UC5
U -- UC6
U -- UC7
U -- UC8
U -- UC9
U -- UC10

UC2a .> UC2 : <<extend>>
UC2b .> UC2 : <<extend>>
UC2c .> UC2 : <<extend>>

UC2a --> IA
UC2b --> BA
UC2c --> BA

A -- UC4
@enduml